{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "allowJs": false,
    "checkJs": false,
    "incremental": true,
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@tensaw/runtime": ["packages/runtime/src/index.ts"],
      "@tensaw/runtime/*": ["packages/runtime/src/*"],
      "@tensaw/design-system": ["packages/design-system/src/index.ts"],
      "@tensaw/design-system/*": ["packages/design-system/src/*"],
      "@tensaw/codes": ["packages/codes/src/index.ts"],
      "@tensaw/codes/*": ["packages/codes/src/*"],
      "@tensaw/visualization": ["packages/visualization/src/index.ts"],
      "@tensaw/visualization/*": ["packages/visualization/src/*"],
      "@tensaw/composition": ["packages/composition/src/index.ts"],
      "@tensaw/composition/*": ["packages/composition/src/*"],
      "@tensaw/archetypes": ["packages/archetypes/src/index.ts"],
      "@tensaw/archetypes/*": ["packages/archetypes/src/*"],
      "@tensaw/actions": ["packages/actions/src/index.ts"],
      "@tensaw/actions/*": ["packages/actions/src/*"],
      "@tensaw/worklist": ["packages/worklist/src/index.ts"],
      "@tensaw/worklist/*": ["packages/worklist/src/*"],
      "@tensaw/mock-server": ["packages/mock-server/src/index.ts"],
      "@tensaw/mock-server/*": ["packages/mock-server/src/*"],
      "@tensaw/wired-components": ["packages/wired-components/src/index.ts"],
      "@tensaw/wired-components/*": ["packages/wired-components/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo", "coverage"]
}
