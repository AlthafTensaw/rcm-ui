{
  "name": "@tensaw/actions",
  "version": "0.0.1",
  "private": true,
  "description": "Typed action contract — every backend call the UI makes. Implements docs/ACTION_CONTRACT.md.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./registry": "./src/registry/index.ts",
    "./dispatcher": "./src/dispatcher/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./patterns": "./src/patterns/optimistic.ts",
    "./utils": "./src/utils/endpoint.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tensaw/runtime": "workspace:*",
    "zod": "3.23.8"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@testing-library/react": "16.0.1",
    "@types/react": "18.3.11",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vitest": "2.1.2"
  }
}
