{
  "name": "@tensaw/mock-server",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-side mock backend for the patient app. MSW handlers + deterministic fixtures + Zod schemas shared with the OpenAPI emitter.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/ar.ts",
    "./fixtures": "./src/fixtures/arRows.ts",
    "./handlers": "./src/handlers/arHandlers.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tensaw/runtime": "workspace:*",
    "msw": "2.4.9",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "vitest": "2.1.2"
  }
}
