{
  "name": "@tensaw/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Platform runtime: Zustand stores, TanStack Query client, event bus, API client, HIPAA primitives, bootstrap. Migrated from Redux Toolkit + RTK Query per ADR-001.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./events": "./src/events/index.ts",
    "./api": "./src/api/index.ts",
    "./effects": "./src/effects/index.ts",
    "./stores": "./src/stores/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "aws-amplify": "6.6.4",
    "lodash-es": "^4.17.21",
    "zod": "3.23.8",
    "zustand": "^4.5.5"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "18.3.11",
    "react": "18.3.1"
  }
}
