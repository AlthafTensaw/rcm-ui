{
  "name": "@tensaw/visualization",
  "version": "0.0.0",
  "private": true,
  "description": "Charts (Recharts), KPI cards with directional color, unified StatusBadge taxonomy registry, grid cell renderers, native iframe DocumentViewer. Phase 5 of the v3 plan.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./charts": "./src/charts/index.ts",
    "./kpi": "./src/kpi/index.ts",
    "./status": "./src/status/index.ts",
    "./cells": "./src/cells/index.ts",
    "./documents": "./src/documents/index.ts",
    "./display": "./src/display/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tensaw/codes": "workspace:*",
    "@tensaw/design-system": "workspace:*",
    "@tensaw/runtime": "workspace:*",
    "recharts": "2.12.7"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.0.1",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
