    "./widgets": "./src/widgets/index.ts",
    "./zones": "./src/zones/index.ts",
    "./shells": "./src/shells/index.ts",
    "./surfaces": "./src/surfaces/index.ts",
    "./grids": "./src/grids/index.ts",
    "./data-display": "./src/data-display/index.ts",
    "./chrome": "./src/chrome/index.tsx",
