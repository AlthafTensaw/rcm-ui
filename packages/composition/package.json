{
  "name": "@tensaw/composition",
  "version": "0.0.0",
  "private": true,
  "description": "Layout/orchestration components: ArchetypeShell, ZoneRenderer, ContainerRenderer, WidgetHost, SurfaceHost, SchemaDataGrid, page chrome. Phase 6 of the v3 plan.",
