# Tensaw UI Platform — Environment Variables
# Copy to .env.local and fill in values. NEVER commit filled-in env files.

# === Required ===

# API gateway base URL (e.g., https://api.dev.tensaw.health)
VITE_API_BASE_URL=

# AWS Cognito configuration
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# App identity
VITE_APP_ID=patient
VITE_BUILD_VERSION=0.0.0-dev

# Stripe (publishable key only — never put secret keys in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=

# === Optional ===

# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Feature flags endpoint
VITE_FEATURE_FLAGS_URL=

# Idle timeout in seconds (default 900 = 15 min)
VITE_IDLE_TIMEOUT_SECONDS=900

# Google Maps JavaScript API key (Places Autocomplete). Optional — AddressField
# falls back to manual entry if not provided. Restrict the key by HTTP referrer
# in the Google Cloud console before shipping.
VITE_GOOGLE_MAPS_API_KEY=
